<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Dash0 Semantic Conventions</title>
<style>
  :root {
    --bg: #111111;
    --bg-surface: #1a1a1a;
    --bg-elevated: #212121;
    --fg: #ffffff;
    --fg-secondary: #969696;
    --fg-muted: #757575;
    --border: #2c2c2c;
    --border-subtle: #222222;
    --link: #e8875b;
    --link-hover: #f4a47a;
    --code-bg: #1a1a1a;
    --code-border: #2c2c2c;
    --nav-bg: #141414;
    --nav-active: #1e1e1e;
    --nav-hover: #1a1a1a;
    --table-header: #1a1a1a;
    --table-stripe: #151515;
    --accent: #e8875b;
    --accent-dim: rgba(232, 135, 91, 0.15);
    --radius: 8px;
    --radius-sm: 4px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--fg);
    display: flex;
    min-height: 100vh;
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Sidebar */
  nav {
    width: 260px;
    min-width: 260px;
    background: var(--nav-bg);
    border-right: 1px solid var(--border-subtle);
    padding: 0;
    overflow-y: auto;
    position: sticky;
    top: 0;
    height: 100vh;
  }
  nav .logo {
    padding: 1.25rem 1.25rem 1rem;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  nav .logo svg {
    height: 16px;
    width: auto;
    flex-shrink: 0;
  }
  nav .section-title {
    padding: 1rem 1.25rem 0.35rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
  }
  nav a {
    display: block;
    padding: 0.35rem 1.25rem 0.35rem 1.75rem;
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: 0.82rem;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
  }
  nav a:hover {
    color: var(--fg);
    background: var(--nav-hover);
  }
  nav a.active {
    color: var(--fg);
    background: var(--nav-active);
    border-left-color: var(--accent);
  }

  /* Main content */
  main {
    flex: 1;
    max-width: 920px;
    padding: 2.5rem 3.5rem;
    overflow-x: auto;
  }
  main h1 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }
  main h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-subtle);
    letter-spacing: -0.01em;
  }
  main h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  main p {
    margin: 0.6rem 0;
    color: var(--fg-secondary);
    line-height: 1.7;
  }
  main a { color: var(--link); text-decoration: none; transition: color 0.15s; }
  main a:hover { color: var(--link-hover); }

  /* Code */
  main code {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    font-family: "SF Mono", "Fira Code", "Fira Mono", Menlo, Consolas, monospace;
    font-size: 0.82em;
    color: var(--accent);
  }
  main pre {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 1rem 0;
  }
  main pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--fg-secondary);
  }

  /* Tables */
  main table {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.84rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  main th {
    background: var(--table-header);
    text-align: left;
    padding: 0.6rem 0.85rem;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    border-bottom: 1px solid var(--border);
  }
  main td {
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--fg-secondary);
  }
  main tr:last-child td { border-bottom: none; }
  main tr:nth-child(even) { background: var(--table-stripe); }
  main tr:hover td { background: var(--nav-active); }

  /* Blockquotes / callouts */
  main blockquote {
    border-left: 3px solid var(--accent);
    background: var(--accent-dim);
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--fg-secondary);
  }

  /* Lists */
  main ul, main ol { margin: 0.6rem 0 0.6rem 1.5rem; color: var(--fg-secondary); }
  main li { margin: 0.3rem 0; line-height: 1.7; }
  main li code { font-size: 0.8em; }

  /* Badges */
  main img[src*="badge"] { vertical-align: middle; border-radius: 3px; }

  /* Strong */
  main strong { color: var(--fg); font-weight: 600; }

  /* Loading */
  #loading { color: var(--fg-muted); font-style: italic; }

  /* Responsive */
  @media (max-width: 768px) {
    body { flex-direction: column; }
    nav {
      width: 100%;
      min-width: 100%;
      height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
    }
    main { padding: 1.5rem 1.25rem; }
  }
</style>
</head>
<body>
